{
  "name": "opencode-ollama-websearch",
  "version": "0.1.0",
  "description": "OpenCode plugin for Ollama web search and web fetch",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && bun run changeset publish",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.17.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@opencode-ai/plugin": "^1.17.8",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "opencode",
    "plugin",
    "ollama",
    "web-search"
  ],
  "license": "MIT"
}
